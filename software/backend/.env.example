# Environment Configuration Template
# Copy this to .env and fill in your values

PORT=3003

# Optional: force advertised backend endpoint for hotspot/multi-NIC setups
# If set, these values are returned by /api/server-info and UDP discovery
# Prefer URL when using domain/tunnel; use IP for local hotspot/LAN.
ADVERTISED_SERVER_URL=
ADVERTISED_SERVER_IP=

# Runtime Mode
# Supported combinations:
# - Local development/demo: STORAGE_MODE=LOCAL and AUTH_MODE=LOCAL
# - Cloud/production: STORAGE_MODE=CLOUD and AUTH_MODE=FIREBASE
STORAGE_MODE=LOCAL
AUTH_MODE=LOCAL

# Hardware Device Auth
# Used by the ESP32 to authenticate with this backend
DEVICE_ID=ESP32_CLASSROOM_01
DEVICE_SECRET=A1B2C3D4_SECRET

# Firebase Credentials
# Paste the minified JSON contents of your serviceAccountKey.json here for cloud hosting
# FIREBASE_SERVICE_ACCOUNT='{"type": "service_account", "project_id": "...", ...}'

# Enrollment timeout guards (milliseconds)
# Minimum enforced in server code:
# ENROLL_IN_PROGRESS_TIMEOUT_MS >= 30000
# ENROLL_AUTHORIZED_TIMEOUT_MS >= 60000
ENROLL_IN_PROGRESS_TIMEOUT_MS=300000
ENROLL_AUTHORIZED_TIMEOUT_MS=86400000

# SMTP (Gmail) - used for sending welcome and session summary emails
# For Gmail, generate an App Password (16 chars) in your Google Account security settings
# and set the values below. Do NOT commit real credentials to the repository.
SMTP_EMAIL=adminattendify@gmail.com
SMTP_APP_PASSWORD=rmqn lrhw wfcy nkpw

# PUBLIC_BASE_URL - used to generate links inside emails (set this when deploying)
# Example: https://attendify.onrender.com
PUBLIC_BASE_URL=
